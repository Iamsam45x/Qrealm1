# FastAPI backend — copy to .env in this folder.

# PostgreSQL (SQLAlchemy + psycopg2)
DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/mydb

ENVIRONMENT=development
PORT=4000

# CORS: dev + production frontends (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://my-production-frontend.com
FRONTEND_URL=http://localhost:3000

JWT_SECRET_KEY=change-me-in-production
JWT_REFRESH_SECRET_KEY=change-me-in-production

# Cookies: use secure cookies behind HTTPS in production
COOKIE_SECURE=false

# =============================================================================
# FIREBASE ADMIN SDK
# =============================================================================
# Copy the entire contents of your Firebase service account JSON file
# and paste it as the value below. Keep the quotes intact.
# Example format (DO NOT use these values):
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/...%40....iam.gserviceaccount.com"}'
